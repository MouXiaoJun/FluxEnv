{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FluxEnv",
  "version": "0.1.2",
  "identifier": "com.fluxenv.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FluxEnv",
        "width": 900,
        "height": 620,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4MjRDQjVGQzEwREE2QjAKUldTd3BnM0JYOHNrR01FZCtLY1hRVG9ZOFRPV2tuUVN6RDRobE9LbWVIdzdkU2J5ZnhVMHNiU3oK",
      "endpoints": [
        "https://github.com/MouXiaoJun/FluxEnv/releases/latest/download/latest.json"
      ]
    }
  }
}
